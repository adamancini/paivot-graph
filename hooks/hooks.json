{
  "description": "paivot-graph hooks -- vault consultation, knowledge capture, stop reminder, session logging, scope guard, dispatcher mode (powered by pvg)",
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Edit|Write|Bash",
        "hooks": [
          {
            "type": "command",
            "command": "pvg guard",
            "timeout": 5
          }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "pvg hook user-prompt",
            "timeout": 5
          }
        ]
      }
    ],
    "SubagentStart": [
      {
        "matcher": "paivot-graph:business-analyst|paivot-graph:designer|paivot-graph:architect",
        "hooks": [
          {
            "type": "command",
            "command": "pvg hook subagent-start",
            "timeout": 5
          }
        ]
      }
    ],
    "SubagentStop": [
      {
        "matcher": "paivot-graph:business-analyst|paivot-graph:designer|paivot-graph:architect",
        "hooks": [
          {
            "type": "command",
            "command": "pvg hook subagent-stop",
            "timeout": 5
          }
        ]
      }
    ],
    "SessionStart": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "pvg hook session-start",
            "timeout": 15
          }
        ]
      }
    ],
    "PreCompact": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "pvg hook pre-compact",
            "timeout": 10
          }
        ]
      }
    ],
    "Stop": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "pvg hook stop",
            "timeout": 10
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Read|Write|Edit",
        "hooks": [
          {
            "type": "command",
            "command": "bash -c 'SCRIPT=$(find ~/.claude/plugins/cache/paivot-graph -name \"memory-vault-shadow.sh\" -type f 2>/dev/null | head -1); [ -n \"$SCRIPT\" ] && bash \"$SCRIPT\" || true'",
            "timeout": 10
          }
        ]
      }
    ],
    "SessionEnd": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "pvg hook session-end",
            "timeout": 10
          }
        ]
      }
    ]
  }
}
